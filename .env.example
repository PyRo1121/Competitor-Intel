# Competitor Intel — copy to .env and adjust (never commit .env)
# See docs/PIPELINE.md, docs/SCHEDULING.md, docs/EXECUTION_CHECKLIST.md (P0-A)

# --- Core paths ---
CI_DB_PATH=data/competitor_intel.db
# COMPETITOR_INTEL_ROOT=/path/to/Competitor-Intel

# --- Daily pipeline (prod: use `make daily-prod` or mirror these flags) ---
CI_SKIP_GROK_X=1
CI_STRICT_PIPELINE=1
CI_REQUIRE_DEDUP_INDEX=1
# Parallel fetch (tune per machine)
# CI_PARALLEL_COLLECTORS=4
# CI_INGEST_STAGING=1
# CI_HN_SKIP_ALGOLIA=1
# CI_RSS_FETCH_WORKERS=20
# CI_HN_FETCH_WORKERS=24
# CI_WEBSITE_FETCH_WORKERS=16
# Rollups default ON when unset; opt out per rollup:
# CI_COMPANY_DATA_ROLLUP=0
# CI_REGULATORY_LICENSE_ROLLUP=0
# CI_CAP_TABLE_ROLLUP=0
# CI_DAILY_DRY_RUN=0

# --- Hermes / Grok X (optional) ---
# HERMES_AGENT_ROOT=~/.hermes/hermes-agent
# CI_DISABLE_HERMES=0
# CI_REQUIRE_GROK_X=0

# --- Enrichment / external APIs (optional) ---
# GITHUB_TOKEN=
# DISCORD_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# DISCORD_GUILD_ID=

# --- Linear (CI sync + local scripts; never commit the key) ---
# LINEAR_API_KEY=lin_api_...
# GitHub Actions: add same value as repository secret LINEAR_API_KEY

# --- Ollama / semantic search ---
# CI_OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_HOST=http://127.0.0.1:11434
# CI_OLLAMA_MODEL=

# --- SEC / EDGAR (Form D = US private fundraising; bulk is weekly, not daily) ---
# EDGAR_TRACKED_CIKS=
# EDGAR_FORM_D_BULK=0
# EDGAR_FORM_D_BULK_MAX=20000
# Weekly: make edgar-form-d-weekly  (or Hermes cron_edgar_weekly.py)
