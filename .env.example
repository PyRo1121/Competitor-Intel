# Competitor Intel — environment template
# Copy to repo root: cp .env.example .env

# SQLite database (default: <monorepo>/data/competitor_intel.db)
CI_DB_PATH=/home/pyro1121/Documents/Competitor-Intel/data/competitor_intel.db

# API
CI_API_PORT=3000
CI_API_HOST=0.0.0.0

# Optional: Discord alerts
# DISCORD_WEBHOOK_URL=

# Optional: GitHub rate limit token
# CI_RATE_GITHUB_TOKEN=

# Ollama embeddings
CI_OLLAMA_HOST=http://localhost:11434
CI_OLLAMA_MODEL=qwen3-embedding:4b
