{
  "include": ["src", "collectors", "reports", "tests", "utils", "alembic", "*.py"],
  "exclude": [".venv", "__pycache__", "*.egg-info"],
  "extraPaths": ["src"],
  "venvPath": ".",
  "venv": ".venv",
